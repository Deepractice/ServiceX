{
  "name": "@servicexjs/core",
  "version": "0.4.0",
  "description": "ServiceX core — domain primitives, DI, DrizzleRepository, types",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "import": "./src/domain/index.ts"
    },
    "./repository": {
      "types": "./src/repository/index.ts",
      "import": "./src/repository/index.ts"
    },
    "./rpc": {
      "types": "./src/rpc/index.ts",
      "import": "./src/rpc/index.ts"
    },
    "./event": {
      "types": "./src/event/index.ts",
      "import": "./src/event/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "reflect-metadata": "^0.2.0",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./domain": {
        "types": "./dist/domain/index.d.ts",
        "import": "./dist/domain/index.js"
      },
      "./repository": {
        "types": "./dist/repository/index.d.ts",
        "import": "./dist/repository/index.js"
      },
      "./rpc": {
        "types": "./dist/rpc/index.d.ts",
        "import": "./dist/rpc/index.js"
      },
      "./event": {
        "types": "./dist/event/index.d.ts",
        "import": "./dist/event/index.js"
      }
    }
  }
}
