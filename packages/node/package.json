{
  "name": "@servicexjs/node",
  "version": "0.4.0",
  "description": "Node.js runtime adapter for ServiceX — for development and testing",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@servicexjs/core": "workspace:*",
    "hono": "^4.0.0",
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.0",
    "typescript": "^5.7.0",
    "tsup": "^8.5.1"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
